# -----------------------------------------------------------------------------
# Axoworks Companion - Configuration Template
# -----------------------------------------------------------------------------
# Instructions: Copy this file, rename it to .env, and adjust the values 
# to match your local deployment environment.

# LLM Configuration (Ollama)
OLLAMA_MODEL=qwen3.6:35b
OLLAMA_BASE_URL=http://localhost:11434

# API Configuration
API_PORT=8000

# Revit MCP Server Configuration
# Note: The bridge automatically discovers the dynamic pipe name using this prefix.
REVIT_PIPE_PREFIX=\\.\pipe\revit-mcp

# -----------------------------------------------------------------------------
# Governor (Traffic Control Layer)
# -----------------------------------------------------------------------------
# Seconds before emitting an interim "still processing" response to prevent
# the LLM agent from timing out and retrying.
GOVERNOR_HEARTBEAT_THRESHOLD_S=25

# How long (seconds) completed results stay cached for dedup.
# Retries within this window get the cached result instantly.
GOVERNOR_CACHE_TTL_S=10

# Max concurrent bridge calls (should match Revit STA constraint = 1).
GOVERNOR_MAX_CONCURRENT=1

# Comma-separated categories that are rejected when include_geometry=True
# (these categories typically contain thousands of elements).
GOVERNOR_DANGEROUS_CATEGORIES=Generic Models,Detail Items,Lines
